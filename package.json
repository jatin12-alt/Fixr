{
  "name": "fixr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:prisma:generate": "prisma generate",
    "db:prisma:migrate": "prisma migrate dev",
    "db:prisma:deploy": "prisma migrate deploy",
    "db:prisma:studio": "prisma studio",
    "db:seed": "tsx lib/seed.ts",
    "deploy:build": "next build",
    "deploy:check": "npm run type-check && npm run lint && npm run deploy:build",
    "postinstall": "prisma generate",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "npm run test && npm run test:e2e",
    "load-test": "k6 run tests/load/api-load-test.js",
    "load-test:db": "k6 run tests/load/db-load-test.js",
    "find-issues": "bash scripts/find-issues.sh"
  },
  "dependencies": {
    "@clerk/nextjs": "^5.0.0",
    "@clerk/themes": "^2.4.57",
    "@neondatabase/serverless": "^0.9.0",
    "@octokit/rest": "^20.0.0",
    "@types/three": "^0.183.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.30.0",
    "framer-motion": "^12.38.0",
    "groq-sdk": "^0.3.0",
    "lucide-react": "^0.370.0",
    "next": "15.0.0-rc.0",
    "react": "^19.0.0-rc.0",
    "react-dom": "^19.0.0-rc.0",
    "svix": "^1.21.0",
    "tailwind-merge": "^2.2.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.21.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "15.0.0-rc.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0"
  }
}
