# =============================================================================
# FIXR - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local for development
# Add these to Vercel Environment Variables for production

# =============================================================================
# DATABASE (REQUIRED)
# =============================================================================
# For Neon PostgreSQL (recommended for production)
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# For local PostgreSQL
# DATABASE_URL="postgresql://username:password@localhost:5432/fixr"

# =============================================================================
# AI SERVICES (OPTIONAL)
# =============================================================================
# For Groq AI analysis and auto-fix
GROQ_API_KEY="gsk_..."

# =============================================================================
# CLERK AUTHENTICATION (REQUIRED)
# =============================================================================
# Get these from: https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk URLs (customize as needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# =============================================================================
# EMAIL NOTIFICATIONS (OPTIONAL)
# =============================================================================
# Get API key from: https://resend.com/
RESEND_API_KEY="re_..."

# Email from address (must be verified in Resend)
FROM_EMAIL="noreply@yourdomain.com"

# =============================================================================
# PUSH NOTIFICATIONS (OPTIONAL)
# =============================================================================
# Generate these with: npx web-push generate-vapid-keys
# Or use: https://web-push-codelab.glitch.me/
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BMf..._"
VAPID_PRIVATE_KEY="..."
VAPID_EMAIL="your-email@example.com"

# =============================================================================
# GITHUB INTEGRATION (REQUIRED)
# =============================================================================
# Create OAuth App at: https://github.com/settings/applications/new
GITHUB_CLIENT_ID="..."
GITHUB_CLIENT_SECRET="..."

# Production callback URL (update after deployment)
NEXT_PUBLIC_GITHUB_CALLBACK_URL="https://your-app.vercel.app/api/webhook/github/callback"

# Development callback URL
# NEXT_PUBLIC_GITHUB_CALLBACK_URL="http://localhost:3000/api/webhook/github/callback"

# =============================================================================
# WEBHOOK SECRETS (RECOMMENDED)
# =============================================================================
# Generate random secret for webhook validation
# Use: openssl rand -base64 32
GITHUB_WEBHOOK_SECRET="..."

# =============================================================================
# OPTIONAL: ANALYTICS & MONITORING
# =============================================================================
# Vercel Analytics (automatically configured)
NEXT_PUBLIC_VERCEL_ANALYTICS="1"

# Sentry for error tracking (free tier - 5k errors/month)
# Get DSN from: https://sentry.io/
NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="fixr"
SENTRY_AUTH_TOKEN="your-sentry-auth-token"

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Plausible Analytics (optional - $9/mo or self-hosted)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="your-app.vercel.app"

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 1. Add all variables (except NEXT_PUBLIC_*) to Vercel Environment Variables
# 2. Add NEXT_PUBLIC_ variables to Vercel Environment Variables (build time)
# 3. Never commit .env.local to version control
# 4. Use different values for development and production
# 5. Rotate secrets regularly for security

# =============================================================================
# PRODUCTION URL UPDATES NEEDED
# =============================================================================
# After deployment, update these in your services:
# - Clerk: Add production URL to allowed origins
# - GitHub OAuth: Update callback URL to production
# - GitHub Webhooks: Update payload URL to production
# - Resend: Verify production domain for sending emails
